# =============================================================================
# OpenInsight Local Development Environment
# =============================================================================
# Copy this file to .env and adjust values as needed.
# DO NOT commit .env to version control.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=openinsight
POSTGRES_PASSWORD=openinsight_dev
POSTGRES_DB=openinsight
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- ClickHouse ---
CLICKHOUSE_USER=openinsight
CLICKHOUSE_PASSWORD=openinsight_dev
CLICKHOUSE_DB=openinsight
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_HOST=localhost
KEYCLOAK_PORT=8080
KEYCLOAK_REALM=openinsight

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Redpanda (Kafka-compatible) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:18081
REDPANDA_CONSOLE_PORT=8888

# --- Superset (future - app profile) ---
SUPERSET_SECRET_KEY=changeme-generate-a-real-secret
SUPERSET_PORT=8088

# --- Cube (future - app profile) ---
# CUBEJS_DEV_MODE=true
# CUBEJS_API_SECRET=changeme-generate-a-real-secret
# CUBEJS_PORT=4000

# --- Trino (app profile) ---
TRINO_PORT=8085

# --- Apache Hop (pipeline profile) ---
HOP_WEB_PORT=8090

# --- Airflow (pipeline profile) ---
AIRFLOW_PORT=8081
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_WEBSERVER_SECRET_KEY=openinsight-airflow-dev-secret
# AIRFLOW__CORE__FERNET_KEY= generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# AIRFLOW_KEYCLOAK_CLIENT_SECRET=airflow-dev-secret
