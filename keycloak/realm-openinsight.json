{
  "realm": "openinsight",
  "enabled": true,
  "displayName": "OpenInsight",
  "displayNameHtml": "<b>OpenInsight</b>",
  "loginWithEmailAllowed": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "verifyEmail": false,
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespan": 5184000,
  "bruteForceProtected": true,
  "maxFailureWaitSeconds": 900,
  "failureFactor": 5,
  "waitIncrementSeconds": 60,
  "maxDeltaTimeSeconds": 43200,
  "passwordPolicy": "length(12) and upperCase(1) and digits(1) and specialChars(1) and passwordHistory(5)",
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full platform access, user management",
        "composite": false
      },
      {
        "name": "data-analyst",
        "description": "Query access, dashboard creation, SQL Lab",
        "composite": false
      },
      {
        "name": "viewer",
        "description": "Dashboard viewing only, no SQL Lab, no data export",
        "composite": false
      },
      {
        "name": "data-engineer",
        "description": "Pipeline management, dbt, Airflow access",
        "composite": false
      }
    ],
    "client": {
      "superset": [
        {
          "name": "superset-admin",
          "description": "Superset Admin role"
        },
        {
          "name": "superset-alpha",
          "description": "Superset Alpha role (SQL Lab + dashboard creation)"
        },
        {
          "name": "superset-gamma",
          "description": "Superset Gamma role (dashboard viewers)"
        }
      ],
      "cube": [
        {
          "name": "cube-admin",
          "description": "Full Cube access, manage pre-aggregations, schema changes"
        },
        {
          "name": "cube-query",
          "description": "Query the Cube API (read-only)"
        },
        {
          "name": "cube-export",
          "description": "Export and download data from Cube"
        }
      ],
      "airflow": [
        {
          "name": "airflow-admin",
          "description": "Full Airflow access, manage DAGs, connections, variables"
        },
        {
          "name": "airflow-viewer",
          "description": "View DAGs, logs, run history (no trigger/edit)"
        },
        {
          "name": "airflow-trigger",
          "description": "Trigger DAG runs (but not modify DAGs)"
        }
      ]
    }
  },
  "groups": [
    {
      "name": "Finance",
      "path": "/Finance",
      "realmRoles": [
        "data-analyst"
      ]
    },
    {
      "name": "HR",
      "path": "/HR",
      "realmRoles": [
        "data-analyst"
      ]
    },
    {
      "name": "Engineering",
      "path": "/Engineering",
      "realmRoles": [
        "data-engineer",
        "data-analyst"
      ]
    },
    {
      "name": "Executive",
      "path": "/Executive",
      "realmRoles": [
        "admin"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "superset",
      "name": "Apache Superset",
      "description": "OpenInsight visualization layer",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "superset-dev-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "rootUrl": "http://localhost:8088",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:8088/*"
      ],
      "webOrigins": [
        "http://localhost:8088"
      ],
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "client-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "config": {
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "client_roles",
            "userinfo.token.claim": "true",
            "usermodel.clientRoleMapping.clientId": "superset"
          }
        }
      ]
    },
    {
      "clientId": "cube",
      "name": "Cube Semantic Layer",
